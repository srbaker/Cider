#!/usr/bin/env bash
set -euo pipefail

REQUIRED_PHARO_VERSION="${CIDER_PHARO_VERSION:-13.1}"
PHARO_IMAGE="${CIDER_PHARO_IMAGE:-}"

if ! command -v pharo >/dev/null 2>&1; then
  cat >&2 <<MESSAGE
Pharo is not available on PATH.

Cider Phase 1 expects a local, pinned headless Pharo installation.
Install Pharo ${REQUIRED_PHARO_VERSION}, then make the pharo executable available on PATH.

The container backend is intentionally deferred until the CI/reproducibility phase.
MESSAGE
  exit 1
fi

if [[ -z "${PHARO_IMAGE}" ]]; then
  cat >&2 <<MESSAGE
CIDER_PHARO_IMAGE is not set.

Cider Phase 1 targets the latest released Pharo line, Pharo ${REQUIRED_PHARO_VERSION}.
Set CIDER_PHARO_IMAGE to a local Pharo ${REQUIRED_PHARO_VERSION} image before running Pharo tests.
MESSAGE
  exit 1
fi

pharo --headless --version | grep "${REQUIRED_PHARO_VERSION}" >/dev/null
pharo --headless "${PHARO_IMAGE}" st pharo/scripts/run-tests.st
