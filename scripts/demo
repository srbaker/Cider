#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SWIFTPM_CACHE_DIR="${CIDER_SWIFTPM_CACHE_DIR:-${ROOT_DIR}/.build/swiftpm-cache}"
SWIFTPM_CONFIG_DIR="${CIDER_SWIFTPM_CONFIG_DIR:-${ROOT_DIR}/.build/swiftpm-config}"
SWIFTPM_SECURITY_DIR="${CIDER_SWIFTPM_SECURITY_DIR:-${ROOT_DIR}/.build/swiftpm-security}"

export CLANG_MODULE_CACHE_PATH="${CIDER_CLANG_MODULE_CACHE_PATH:-${ROOT_DIR}/.build/clang-module-cache}"

mkdir -p \
  "${SWIFTPM_CACHE_DIR}" \
  "${SWIFTPM_CONFIG_DIR}" \
  "${SWIFTPM_SECURITY_DIR}" \
  "${CLANG_MODULE_CACHE_PATH}"

"${ROOT_DIR}/scripts/prepare-pharo"

# Prove the same script the app loads can accept an event and emit a live update.
# This keeps a no-window demo run useful and fails early before opening the app.
source "${ROOT_DIR}/.build/pharo/env"
DEMO_WIRE="$(
  printf '%s\n' 'CIDER:{"receiver":"SpButtonPresenter","selector":"click","id":"n4"}' |
  HOME="${CIDER_PHARO_HOME}" "${CIDER_PHARO_VM}" \
    --headless "${CIDER_PHARO_IMAGE}" \
    st pharo/scripts/serve-interactive-click.st
)"
if [[ "${DEMO_WIRE}" != *'"title":"Cider Interactive Click"'* ]] ||
  [[ "${DEMO_WIRE}" != *'"label":"Not clicked"'* ]] ||
  [[ "${DEMO_WIRE}" != *'"label":"Clicked"'* ]]; then
  cat >&2 <<MESSAGE
The interactive demo did not emit the expected live button-click update.
MESSAGE
  exit 1
fi

cd "${ROOT_DIR}"

swift build \
  --disable-sandbox \
  --cache-path "${SWIFTPM_CACHE_DIR}" \
  --config-path "${SWIFTPM_CONFIG_DIR}" \
  --security-path "${SWIFTPM_SECURITY_DIR}"

BIN_DIR="$(swift build \
  --disable-sandbox \
  --cache-path "${SWIFTPM_CACHE_DIR}" \
  --config-path "${SWIFTPM_CONFIG_DIR}" \
  --security-path "${SWIFTPM_SECURITY_DIR}" \
  --show-bin-path)"

APP_BUNDLE="${ROOT_DIR}/.build/Cider.app"
APP_CONTENTS="${APP_BUNDLE}/Contents"
APP_MACOS="${APP_CONTENTS}/MacOS"

rm -rf "${APP_BUNDLE}"
mkdir -p "${APP_MACOS}"

cp "${BIN_DIR}/Cider" "${APP_MACOS}/CiderBinary"
cp -R "${BIN_DIR}/Cider_CiderCore.bundle" "${APP_BUNDLE}/Cider_CiderCore.bundle"

cat > "${APP_CONTENTS}/Info.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>
  <string>Cider</string>
  <key>CFBundleIdentifier</key>
  <string>dev.sidechain.Cider</string>
  <key>CFBundleName</key>
  <string>Cider</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>0.1.0</string>
  <key>LSMinimumSystemVersion</key>
  <string>14.0</string>
  <key>NSPrincipalClass</key>
  <string>NSApplication</string>
</dict>
</plist>
PLIST

cat > "${APP_MACOS}/Cider" <<LAUNCHER
#!/usr/bin/env bash
set -euo pipefail
cd "${ROOT_DIR}"
exec "\$(dirname "\$0")/CiderBinary"
LAUNCHER
chmod +x "${APP_MACOS}/Cider"

if [[ "${CIDER_DEMO_OPEN:-1}" == "1" ]]; then
  open -n "${APP_BUNDLE}"
else
  echo "Built demo app: ${APP_BUNDLE}"
fi
