#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

"${ROOT_DIR}/scripts/prepare-pharo" >/dev/null

# shellcheck disable=SC1091
source "${ROOT_DIR}/.build/pharo/env"

HOME="${CIDER_PHARO_HOME}" "${CIDER_PHARO_VM}" \
  --headless "${CIDER_PHARO_IMAGE}" \
  st pharo/scripts/emit-calypso-browser.st |
  grep '^CIDER:'
